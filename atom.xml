  <entry>
    <title>「栈模拟迭代」—递归算法优化</title>
    <link href="https://blog.kayleh.top/stack-simulation-iteration/"/>
    <id>https://blog.kayleh.top/stack-simulation-iteration/</id>
    <published>2022-03-12T18:15:57.000Z</published>
